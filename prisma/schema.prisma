// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String                @id @default(cuid())
  email               String                @unique
  passwordHash        String
  monthlyBudget       Float                 @default(20000)
  streakCount         Int                   @default(0)
  lastLoginDate       DateTime?
  expenses            Expense[]
  savings             Savings[]
  investments         Investment[]
  savingsGoals        SavingsGoal[]
  investmentWatchlist InvestmentWatchlist[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  category    String
  date        DateTime @default(now())
  note        String?
  isRecurring Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SavingsGoal {
  id           String   @id @default(cuid())
  name         String
  targetAmount Float
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model InvestmentWatchlist {
  id        String   @id @default(cuid())
  assetName String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Savings {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime
  note      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("savings")
}

model Investment {
  id        String   @id @default(cuid())
  type      String
  amount    Float
  date      DateTime
  note      String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("investments")
}
